generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String?
  phone     String?   @unique
  phoneVerified Boolean @default(false)
  bookings  Booking[]
  verificationCodes VerificationCode[]
  createdAt DateTime  @default(now())
}

model Flight {
  id                  String   @id @default(uuid())
  origin              String
  destination         String
  airline             String
  flightNumber        String
  departure           DateTime
  arrival             DateTime
  basePriceCents      Int
  bookings            Booking[]
  registeredAirline   Airline? @relation(fields: [registeredAirlineId], references: [id])
  registeredAirlineId String?
}

model Airline {
  id        String   @id @default(uuid())
  name      String   @unique
  email     String   @unique
  password  String
  logoUrl   String?
  flights   Flight[]
  createdAt DateTime @default(now())
}

model Booking {
  id              String   @id @default(uuid())
  user            User     @relation(fields: [userId], references: [id])
  userId          String
  flight          Flight   @relation(fields: [flightId], references: [id])
  flightId        String
  status          String
  priceCents      Int
  seatNumber      String?
  passengerNames  String?
  luggageOption   String?
  mealOption      String?
  wifiOption      String?
  insuranceOption String?
  createdAt       DateTime @default(now())
  payments        Payment[]
}

model Payment {
  id           String   @id @default(uuid())
  booking      Booking  @relation(fields: [bookingId], references: [id])
  bookingId    String
  method       String
  amountCents  Int
  status       String
  upiId        String?
  cardLast4    String?
  cardBrand    String?
  createdAt    DateTime @default(now())
}

model VerificationCode {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  type       String
  code       String
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())
}


